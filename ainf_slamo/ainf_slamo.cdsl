import "Lidar3D.idsl";
import "Webots2Robocomp.idsl";
import "OmniRobot.idsl";
import "JoystickAdapter.idsl";
import "FullPoseEstimationPub.idsl";
import "Navigator.idsl";
import "ImageSegmentation.idsl";

Component ainf_slamo
{
    Communications
    {
        requires Lidar3D, Lidar3D, Webots2Robocomp, OmniRobot, ImageSegmentation;
        implements Navigator;
        subscribesTo JoystickAdapter, FullPoseEstimationPub;
    };
    language Cpp11;
    gui Qt(QWidget);

};
